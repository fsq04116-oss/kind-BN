    val Background = Color(0xFF080D10)
    val BottomBar = Color(0xFF0D1418)
    val Panel = Color(0xFF10191E)
    val Chip = Color(0xFF172329)
    val Console = Color(0xFF05090B)
    val Track = Color(0xFF223036)
    val Border = Color(0xFF203139)
    val Accent = Color(0xFF42E0B5)
    val Warning = Color(0xFFFFC857)
    val Danger = Color(0xFFFF5D73)
    val TextPrimary = Color(0xFFE9F3F1)
    val TextSecondary = Color(0xFFB8C7C4)
    val TextMuted = Color(0xFF7F9290)
    val ConsoleText = Color(0xFF9EF5D5)
}
