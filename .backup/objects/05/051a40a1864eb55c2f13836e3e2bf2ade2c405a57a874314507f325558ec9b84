private fun severityColor(severity: String): Color = when (severity) {
    "高" -> AppColors.Danger
    "中" -> AppColors.Warning
    else -> AppColors.Accent
}

private fun stateColor(state: String): Color = when {
    state.contains("风险") || state.contains("禁用") || state.contains("未命中") -> AppColors.Danger
    state.contains("未知") || state.contains("空") -> AppColors.TextMuted
    state.contains("正常") || state.contains("启用") || state.contains("存在") || state.contains("发现") || state.contains("命中") -> AppColors.Accent
    else -> AppColors.Warning
}

