    val AccentSoft = Color(0xFFEAF3FF)
    val Warning = Color(0xFFFFA726)
    val Danger = Color(0xFFE53935)
    val TextPrimary = Color(0xFF17212B)
    val TextSecondary = Color(0xFF4B5B6B)
    val TextMuted = Color(0xFF7A8794)
    val PathText = Color(0xFF607D8B)
    val ConsoleText = Color(0xFFE8F5E9)
}
