@Composable
private fun TerminalDialog(controller: RootMonitorController, workDir: String, asRoot: Boolean, onDismiss: () -> Unit) {
    val scope = rememberCoroutineScope()
    var command by remember { mutableStateOf("ls -la") }
    var log by remember { mutableStateOf("内置终端已就绪\n$ $command") }
    var busy by remember { mutableStateOf(false) }
    AlertDialog(
        onDismissRequest = onDismiss,
        title = { Text("内置终端") },
        text = {
            Column {
                OutlinedTextField(value = command, onValueChange = { command = it }, label = { Text("命令") }, modifier = Modifier.fillMaxWidth())
                Spacer(Modifier.height(8.dp))
                Console(log)
            }
        },
        confirmButton = {
            Button(
                enabled = !busy,
                onClick = {
                    scope.launch {
                        busy = true
                        val r = controller.runTerminal(command, workDir, asRoot)
                        log = "$ $command\nexit=${r.exitCode}\n${r.output}"
                        busy = false
                    }
                }
            ) { Text("执行") }
        },
        dismissButton = { TextButton(onClick = onDismiss) { Text("关闭") } }
    )
}

@Composable
private fun ModuleCard(module: ModuleInfo) {
    Panel {
        Row(verticalAlignment = Alignment.Top) {
            Icon(Icons.Outlined.Extension, null, tint = AppColors.Accent, modifier = Modifier.size(26.dp))
            Spacer(Modifier.width(10.dp))
            Column(Modifier.weight(1f)) {
                Row(verticalAlignment = Alignment.CenterVertically) {
                    Text(module.name, color = AppColors.TextPrimary, fontWeight = FontWeight.SemiBold, maxLines = 1, overflow = TextOverflow.Ellipsis, modifier = Modifier.weight(1f))
                    Text(module.state, color = stateColor(module.state), fontSize = 12.sp, fontWeight = FontWeight.Bold)
                }
                Text(module.type, color = AppColors.TextMuted, fontSize = 12.sp)
                Text(module.description, color = AppColors.TextSecondary, fontSize = 13.sp, maxLines = 2, overflow = TextOverflow.Ellipsis)
                if (module.path.isNotBlank()) Text(module.path, color = AppColors.PathText, fontSize = 11.sp, maxLines = 1, overflow = TextOverflow.Ellipsis)
            }
        }
    }
}

@Composable
private fun CheckCard(check: SecurityCheck) {
