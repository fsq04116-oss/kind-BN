@Composable
private fun ShellGuardApp(controller: RootMonitorController) {
    val scope = rememberCoroutineScope()
    var page by remember { mutableStateOf(Page.Shell) }
    var root by remember { mutableStateOf(RootStatus(false, "检测中", "未知", "")) }
    var scan by remember { mutableStateOf(ModuleScan(emptyList(), emptyList(), emptyList(), emptyList())) }
    var busy by remember { mutableStateOf(false) }

    var scriptPath by remember { mutableStateOf("/data/adb/script.sh") }
    var workDir by remember { mutableStateOf("/data/adb") }
    var asRoot by remember { mutableStateOf(true) }
    var protection by remember { mutableStateOf(true) }
    var output by remember { mutableStateOf("等待执行脚本") }
    var chmodMode by remember { mutableStateOf("777") }
    var terminalDialog by remember { mutableStateOf(false) }

    fun refresh() {
        scope.launch {
            busy = true
            root = controller.checkRoot()
            scan = controller.scanModules()
            busy = false
        }
    }

    LaunchedEffect(Unit) { refresh() }

    Scaffold(
        containerColor = AppColors.Background,
        bottomBar = {
            BottomBar(page) { page = it }
        }
    ) { padding ->
        Column(
            Modifier
                .fillMaxSize()
                .background(AppColors.Background)
                .padding(padding)
                .padding(horizontal = 16.dp)
        ) {
            Header(root, busy, onRefresh = ::refresh)
            Spacer(Modifier.height(12.dp))
            when (page) {
                Page.Shell -> ShellPage(
                    scriptPath = scriptPath,
                    onScriptPath = { scriptPath = it },
                    workDir = workDir,
                    onWorkDir = { workDir = it },
                    asRoot = asRoot,
                    onAsRoot = { asRoot = it },
                    protection = protection,
                    onProtection = { protection = it },
                    output = output,
                    chmodMode = chmodMode,
                    onChmodMode = { chmodMode = it },
                    busy = busy,
                    onChmod = {
                        scope.launch {
                            busy = true
                            val r = controller.prepareScript(scriptPath, chmodMode)
                            output = "chmod $chmodMode exit=${r.exitCode}\n${r.output}"
                            busy = false
                        }
                    },
                    onRun = {
                        scope.launch {
                            busy = true
                            val r = controller.runScript(scriptPath, workDir, asRoot, protection)
                            output = "exit=${r.exitCode}\n${r.output}"
                            busy = false
                        }
                    }
                )
                Page.Modules -> ModulesPage(scan)
                Page.Guard -> GuardPage(protection, onProtection = { protection = it }, scriptPath = scriptPath, output = output)
                Page.Settings -> SettingsPage(
                    root = root,
                    workDir = workDir,
                    onOpenTerminal = { terminalDialog = true }
                )
            }
        }
    }

    if (terminalDialog) {
        TerminalDialog(
            controller = controller,
            workDir = workDir,
            asRoot = asRoot,
            onDismiss = { terminalDialog = false }
        )
    }
}

@Composable
private fun Header(root: RootStatus, busy: Boolean, onRefresh: () -> Unit) {
    Column(Modifier.padding(top = 18.dp)) {
        Row(verticalAlignment = Alignment.CenterVertically) {
            Column(Modifier.weight(1f)) {
                Text("ADB Script Guard", color = AppColors.TextPrimary, fontSize = 24.sp, fontWeight = FontWeight.Bold)
                Text("Shell 脚本执行 · Root 模块 · KSU WebUI", color = AppColors.TextMuted, fontSize = 13.sp)
            }
            IconButton(onClick = onRefresh) {
                if (busy) CircularProgressIndicator(Modifier.size(20.dp), strokeWidth = 2.dp, color = AppColors.Accent)
                else Icon(Icons.Outlined.VerifiedUser, contentDescription = "刷新", tint = AppColors.Accent)
            }
        }
        Spacer(Modifier.height(12.dp))
        Panel {
            Row(verticalAlignment = Alignment.CenterVertically) {
                StatusDot(root.available)
                Spacer(Modifier.width(10.dp))
                Column(Modifier.weight(1f)) {
                    Text(if (root.available) "Root 已授权" else "Root 未就绪", color = AppColors.TextPrimary, fontWeight = FontWeight.SemiBold)
                    Text("${root.manager} · SELinux ${root.selinux}", color = AppColors.TextMuted, fontSize = 12.sp)
                }
            }
        }
    }
}

@Composable
private fun ShellPage(
    scriptPath: String,
    onScriptPath: (String) -> Unit,
    workDir: String,
    onWorkDir: (String) -> Unit,
    asRoot: Boolean,
    onAsRoot: (Boolean) -> Unit,
    protection: Boolean,
    onProtection: (Boolean) -> Unit,
    output: String,
    chmodMode: String,
    onChmodMode: (String) -> Unit,
    busy: Boolean,
    onChmod: () -> Unit,
    onRun: () -> Unit
) {
    LazyColumn(verticalArrangement = Arrangement.spacedBy(12.dp), contentPadding = PaddingValues(bottom = 12.dp)) {
        item {
            Panel {
                Text("执行 Shell 脚本", color = AppColors.TextPrimary, fontSize = 18.sp, fontWeight = FontWeight.Bold)
                Spacer(Modifier.height(10.dp))
                OutlinedTextField(
                    value = scriptPath,
                    onValueChange = onScriptPath,
                    modifier = Modifier.fillMaxWidth(),
                    label = { Text("脚本路径") },
                    leadingIcon = { Icon(Icons.Outlined.Code, null) },
                    singleLine = true
                )
                Spacer(Modifier.height(8.dp))
                OutlinedTextField(
                    value = workDir,
                    onValueChange = onWorkDir,
                    modifier = Modifier.fillMaxWidth(),
                    label = { Text("工作目录，默认 /data/adb") },
                    leadingIcon = { Icon(Icons.Outlined.Folder, null) },
                    singleLine = true
                )
                ToggleRow("Root 执行", "使用 su -c 执行脚本", asRoot, onAsRoot)
                ToggleRow("运行保护", "执行前扫描危险命令，命中立即终止", protection, onProtection)
                Spacer(Modifier.height(10.dp))
                PermissionPicker(mode = chmodMode, onModeChange = onChmodMode)
                Spacer(Modifier.height(10.dp))
                Row(horizontalArrangement = Arrangement.spacedBy(8.dp)) {
                    TextButton(onClick = onChmod, modifier = Modifier.weight(1f), enabled = !busy) { Text("赋予执行权限") }
                    Button(
                        onClick = onRun,
                        enabled = !busy,
                        modifier = Modifier.weight(1f),
                        colors = ButtonDefaults.buttonColors(containerColor = AppColors.Accent)
                    ) {
                        Icon(Icons.Outlined.PlayArrow, null, Modifier.size(18.dp))
                        Spacer(Modifier.width(4.dp))
                        Text("执行")
                    }
                }
            }
        }
        item { Console(output) }
        item { RightsFooter() }
    }
}

