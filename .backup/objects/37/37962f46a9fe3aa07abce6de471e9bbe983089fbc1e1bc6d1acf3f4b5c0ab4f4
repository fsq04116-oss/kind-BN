@Composable
private fun PermissionPicker(mode: String, onModeChange: (String) -> Unit) {
    fun bit(indexFromEnd: Int, mask: Int, default: Boolean = true): Boolean =
        mode.getOrNull(mode.length - indexFromEnd)?.digitToIntOrNull()?.let { it and mask != 0 } ?: default

    var ownerR by remember(mode) { mutableStateOf(bit(3, 4)) }
    var ownerW by remember(mode) { mutableStateOf(bit(3, 2)) }
    var ownerX by remember(mode) { mutableStateOf(bit(3, 1)) }
    var groupR by remember(mode) { mutableStateOf(bit(2, 4)) }
    var groupW by remember(mode) { mutableStateOf(bit(2, 2)) }
    var groupX by remember(mode) { mutableStateOf(bit(2, 1)) }
    var otherR by remember(mode) { mutableStateOf(bit(1, 4)) }
    var otherW by remember(mode) { mutableStateOf(bit(1, 2)) }
    var otherX by remember(mode) { mutableStateOf(bit(1, 1)) }
    var suid by remember(mode) { mutableStateOf(mode.length == 4 && ((mode[0].digitToIntOrNull() ?: 0) and 4 != 0)) }
    var sgid by remember(mode) { mutableStateOf(mode.length == 4 && ((mode[0].digitToIntOrNull() ?: 0) and 2 != 0)) }
    var sticky by remember(mode) { mutableStateOf(mode.length == 4 && ((mode[0].digitToIntOrNull() ?: 0) and 1 != 0)) }

    fun sync(
        oR: Boolean = ownerR,
        oW: Boolean = ownerW,
        oX: Boolean = ownerX,
        gR: Boolean = groupR,
        gW: Boolean = groupW,
        gX: Boolean = groupX,
        eR: Boolean = otherR,
        eW: Boolean = otherW,
        eX: Boolean = otherX,
        sUid: Boolean = suid,
        sGid: Boolean = sgid,
        sSticky: Boolean = sticky
    ) {
        val special = (if (sUid) 4 else 0) + (if (sGid) 2 else 0) + if (sSticky) 1 else 0
        val o = (if (oR) 4 else 0) + (if (oW) 2 else 0) + if (oX) 1 else 0
        val g = (if (gR) 4 else 0) + (if (gW) 2 else 0) + if (gX) 1 else 0
        val e = (if (eR) 4 else 0) + (if (eW) 2 else 0) + if (eX) 1 else 0
        onModeChange(if (special > 0) "$special$o$g$e" else "$o$g$e")
    }

    Column(
        Modifier
            .clip(RoundedCornerShape(12.dp))
            .background(AppColors.AccentSoft)
            .padding(10.dp)
    ) {
        Text("权限", color = AppColors.TextPrimary, fontWeight = FontWeight.SemiBold)
        Row(Modifier.fillMaxWidth(), horizontalArrangement = Arrangement.SpaceBetween) {
            Text("", modifier = Modifier.weight(1f))
            Text("读", modifier = Modifier.weight(1f), color = AppColors.TextMuted)
            Text("写", modifier = Modifier.weight(1f), color = AppColors.TextMuted)
            Text("执行", modifier = Modifier.weight(1f), color = AppColors.TextMuted)
        }
        PermissionRow("所有者", ownerR, { ownerR = it; sync(oR = it) }, ownerW, { ownerW = it; sync(oW = it) }, ownerX, { ownerX = it; sync(oX = it) })
        PermissionRow("用户组", groupR, { groupR = it; sync(gR = it) }, groupW, { groupW = it; sync(gW = it) }, groupX, { groupX = it; sync(gX = it) })
        PermissionRow("其它", otherR, { otherR = it; sync(eR = it) }, otherW, { otherW = it; sync(eW = it) }, otherX, { otherX = it; sync(eX = it) })
        Text("---- 特殊权限 ----", color = AppColors.TextMuted, modifier = Modifier.align(Alignment.CenterHorizontally))
        Row(horizontalArrangement = Arrangement.SpaceBetween, modifier = Modifier.fillMaxWidth()) {
            SmallCheck("设置 UID", suid) { suid = it; sync(sUid = it) }
            SmallCheck("设置 GID", sgid) { sgid = it; sync(sGid = it) }
            SmallCheck("粘滞", sticky) { sticky = it; sync(sSticky = it) }
        }
        Text("rwx rwx rwx ($mode)", color = AppColors.Accent, fontWeight = FontWeight.Bold, modifier = Modifier.align(Alignment.CenterHorizontally))
    }
}

