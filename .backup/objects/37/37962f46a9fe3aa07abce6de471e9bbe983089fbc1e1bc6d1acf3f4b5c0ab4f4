@Composable
private fun TerminalPage(controller: RootMonitorController, workDir: String, asRoot: Boolean) {
    val scope = rememberCoroutineScope()
    val focusRequester = remember { FocusRequester() }
    val keyboard = LocalSoftwareKeyboardController.current
    var command by remember { mutableStateOf("ls -la") }
    var log by remember { mutableStateOf("Termux-like shell ready\\n目录: $workDir\\n$ $command") }
    var busy by remember { mutableStateOf(false) }

    fun execute(cmd: String = command) {
        scope.launch {
            busy = true
            val r = controller.runTerminal(cmd, workDir, asRoot)
            log = "$log\\n\\n$ $cmd\\nexit=${r.exitCode}\\n${r.output}"
            busy = false
        }
    }

    Column(
        Modifier
            .fillMaxSize()
            .padding(top = 12.dp)
    ) {
        Row(verticalAlignment = Alignment.CenterVertically) {
            Column(Modifier.weight(1f)) {
                Text("内置 Termux 风格终端", color = AppColors.TextPrimary, fontSize = 22.sp, fontWeight = FontWeight.Bold)
                Text("全屏终端 · $workDir · ${if (asRoot) "root" else "shell"}", color = AppColors.TextMuted, fontSize = 12.sp)
            }
            if (busy) CircularProgressIndicator(Modifier.size(20.dp), strokeWidth = 2.dp, color = AppColors.Accent)
        }
        Spacer(Modifier.height(10.dp))
        Box(Modifier.weight(1f)) {
            Console(log)
        }
        Spacer(Modifier.height(8.dp))
        OutlinedTextField(
            value = command,
            onValueChange = { command = it },
            label = { Text("继续输入命令") },
            modifier = Modifier
                .fillMaxWidth()
                .focusRequester(focusRequester)
        )
        Spacer(Modifier.height(8.dp))
        Row(horizontalArrangement = Arrangement.spacedBy(6.dp), modifier = Modifier.fillMaxWidth()) {
            (1..7).forEach { n ->
                TextButton(
                    onClick = {
                        command += n.toString()
                        focusRequester.requestFocus()
                        keyboard?.show()
                    },
                    modifier = Modifier.weight(1f)
                ) { Text(n.toString()) }
            }
        }
        Row(horizontalArrangement = Arrangement.spacedBy(8.dp), modifier = Modifier.fillMaxWidth()) {
            TextButton(
                onClick = {
                    focusRequester.requestFocus()
                    keyboard?.show()
                },
                modifier = Modifier.weight(1f)
            ) { Text("弹出键盘") }
            TextButton(onClick = { command = "" }, modifier = Modifier.weight(1f)) { Text("清空") }
            Button(onClick = { execute() }, enabled = !busy, modifier = Modifier.weight(1f), colors = ButtonDefaults.buttonColors(containerColor = AppColors.Accent)) {
                Text("执行")
            }
        }
        RightsFooter()
    }
}

