@Composable
private fun StatusDot(active: Boolean) {
    Box(Modifier.size(10.dp).clip(CircleShape).background(if (active) AppColors.Accent else AppColors.Warning))
}

@Composable
private fun BottomBar(page: Page, onPage: (Page) -> Unit) {
    Row(
        Modifier
            .fillMaxWidth()
            .background(AppColors.Panel)
            .padding(horizontal = 14.dp, vertical = 8.dp),
        horizontalArrangement = Arrangement.SpaceAround
    ) {
        Page.entries.forEach {
            val selected = it == page
            Column(
                Modifier
                    .clip(RoundedCornerShape(12.dp))
                    .clickable { onPage(it) }
                    .background(if (selected) AppColors.AccentSoft else Color.Transparent)
                    .padding(horizontal = 16.dp, vertical = 8.dp),
                horizontalAlignment = Alignment.CenterHorizontally
            ) {
                Icon(it.icon, null, tint = if (selected) AppColors.Accent else AppColors.TextMuted, modifier = Modifier.size(20.dp))
                Text(it.title, color = if (selected) AppColors.Accent else AppColors.TextMuted, fontSize = 11.sp)
            }
        }
    }
}

