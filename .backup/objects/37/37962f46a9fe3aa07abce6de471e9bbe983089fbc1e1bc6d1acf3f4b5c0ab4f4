private fun stateColor(state: String): Color = when {
    state.contains("风险") || state.contains("禁用") || state.contains("未命中") -> AppColors.Danger
    state.contains("正常") || state.contains("启用") || state.contains("存在") || state.contains("发现") || state.contains("可用") -> AppColors.Accent
    else -> AppColors.Warning
}

private object AppColors {
    val Background = Color(0xFFF6F8FA)
    val Panel = Color.White
    val Console = Color(0xFF101418)
    val Border = Color(0xFFE1E6EB)
    val Accent = Color(0xFF1677FF)
    val AccentSoft = Color(0xFFEAF3FF)
    val Warning = Color(0xFFFFA726)
    val Danger = Color(0xFFE53935)
    val TextPrimary = Color(0xFF17212B)
    val TextSecondary = Color(0xFF4B5B6B)
    val TextMuted = Color(0xFF7A8794)
    val PathText = Color(0xFF607D8B)
    val ConsoleText = Color(0xFFE8F5E9)
}
