                    Text(module.state, color = stateColor(module.state), fontSize = 12.sp, fontWeight = FontWeight.Bold)
                }
                Text(module.type, color = AppColors.TextMuted, fontSize = 12.sp)
                Text(module.description, color = AppColors.TextSecondary, fontSize = 13.sp, maxLines = 2, overflow = TextOverflow.Ellipsis)
                if (module.path.isNotBlank()) Text(module.path, color = AppColors.PathText, fontSize = 11.sp, maxLines = 1, overflow = TextOverflow.Ellipsis)
            }
        }
    }
}

@Composable
private fun CheckCard(check: SecurityCheck) {
    Panel {
        Row(verticalAlignment = Alignment.CenterVertically) {
            Column(Modifier.weight(1f)) {
                Text(check.name, color = AppColors.TextPrimary, fontWeight = FontWeight.SemiBold)
                Text(check.detail, color = AppColors.TextSecondary, fontSize = 13.sp)
            }
            Text(check.state, color = stateColor(check.state), fontWeight = FontWeight.Bold, fontSize = 12.sp)
        }
    }
}

