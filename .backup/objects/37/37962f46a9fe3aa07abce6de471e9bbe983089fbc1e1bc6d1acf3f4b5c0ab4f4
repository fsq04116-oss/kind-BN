@Composable
private fun ShellGuardApp(controller: RootMonitorController) {
    val scope = rememberCoroutineScope()
    var page by remember { mutableStateOf(Page.Shell) }
    var root by remember { mutableStateOf(RootStatus(false, "检测中", "未知", "")) }
    var scan by remember { mutableStateOf(ModuleScan(emptyList(), emptyList(), emptyList(), emptyList())) }
    var busy by remember { mutableStateOf(false) }

    var scriptPath by remember { mutableStateOf("/data/adb/script.sh") }
    var workDir by remember { mutableStateOf("/data/adb") }
    var asRoot by remember { mutableStateOf(true) }
    var protection by remember { mutableStateOf(true) }
    var output by remember { mutableStateOf("等待执行脚本") }
    var chmodMode by remember { mutableStateOf("777") }
    var permissionDialog by remember { mutableStateOf(false) }
    var signOutput by remember { mutableStateOf("选择 APK 签名方式：公开测试签名 / 自定义签名 / BNSTR 专属签名") }

    fun refresh() {
        scope.launch {
            busy = true
            root = controller.checkRoot()
            scan = controller.scanModules()
            busy = false
        }
    }

    LaunchedEffect(Unit) { refresh() }

    Scaffold(
        containerColor = AppColors.Background,
        bottomBar = {
            BottomBar(page) { page = it }
        }
    ) { padding ->
        Column(
            Modifier
                .fillMaxSize()
                .background(AppColors.Background)
                .padding(padding)
                .padding(horizontal = 16.dp)
        ) {
            if (page == Page.Terminal) {
                TerminalPage(controller = controller, workDir = workDir, asRoot = asRoot)
            } else {
                Header(root, busy, onRefresh = ::refresh)
                Spacer(Modifier.height(12.dp))
                AnimatedContent(
                    targetState = page,
                    transitionSpec = { fadeIn() togetherWith fadeOut() },
                    label = "page"
                ) { selected ->
                    when (selected) {
                        Page.Shell -> ShellPage(
                            scriptPath = scriptPath,
                            onScriptPath = { scriptPath = it },
                            workDir = workDir,
                            onWorkDir = { workDir = it },
                            asRoot = asRoot,
                            onAsRoot = { asRoot = it },
                            protection = protection,
                            onProtection = { protection = it },
                            output = output,
                            busy = busy,
                            onChmod = { permissionDialog = true },
                            onRun = {
                                scope.launch {
                                    busy = true
                                    val r = controller.runScript(scriptPath, workDir, asRoot, protection)
                                    output = "exit=${r.exitCode}\n${r.output}"
                                    busy = false
                                }
                            }
                        )
                        Page.Modules -> ModulesPage(scan)
                        Page.Guard -> GuardPage(protection, onProtection = { protection = it }, scriptPath = scriptPath, output = output)
                        Page.Sign -> SignPage(
                            output = signOutput,
                            onOutput = { signOutput = it }
                        )
                        Page.Terminal -> Unit
                    }
                }
            }
        }
    }

    if (permissionDialog) {
        PermissionDialog(
            mode = chmodMode,
            onModeChange = { chmodMode = it },
            onDismiss = { permissionDialog = false },
            onConfirm = {
                permissionDialog = false
                scope.launch {
                    busy = true
                    val r = controller.prepareScript(scriptPath, chmodMode)
                    output = "chmod $chmodMode exit=${r.exitCode}\n${r.output}"
                    busy = false
                }
            }
        )
    }
}

