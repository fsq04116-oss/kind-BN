        colors = CardDefaults.cardColors(containerColor = AppColors.Panel),
        shape = RoundedCornerShape(14.dp),
        modifier = Modifier
            .fillMaxWidth()
            .border(1.dp, AppColors.Border, RoundedCornerShape(14.dp))
